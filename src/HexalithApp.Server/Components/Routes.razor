<Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="new[] 
    { 
        typeof(HexalithApp.Client._Imports).Assembly,
        typeof(Hexalith.UI.Components._Imports).Assembly,
        typeof(Microsoft.FluentUI.AspNetCore.Components._Imports).Assembly
    }">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
